{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "--prefix", "frontend", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "backend",
      "runtimeExecutable": "backend/.venv/bin/uvicorn",
      "runtimeArgs": ["app.main:app", "--host", "0.0.0.0", "--reload", "--app-dir", "backend"],
      "port": 8000,
      "autoPort": true
    }
  ]
}
