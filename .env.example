# ============================================
# AI-Driven Coding Pipeline - Environment Vars
# ============================================
# Copy to .env and fill in real values:
#   cp .env.example .env

# ---------- Database ----------
POSTGRES_PASSWORD=changeme_postgres_password
DATABASE_URL=postgresql+asyncpg://aicoding:changeme_postgres_password@postgres:5432/aicoding
REDIS_URL=redis://redis:6379/0

# ---------- Auth / JWT ----------
JWT_SECRET=changeme_jwt_secret_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---------- GitHub OAuth ----------
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# ---------- AI Provider Keys ----------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
OPENAI_API_KEY=sk-your-openai-key
GOOGLE_AI_API_KEY=your-google-ai-key

# ---------- n8n Workflow Engine ----------
N8N_BASE_URL=http://n8n:5678
N8N_PASSWORD=changeme_n8n_password

# ---------- Notifications ----------
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ---------- Monitoring ----------
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password

# ---------- CORS ----------
CORS_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost
